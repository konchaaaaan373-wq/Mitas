# ============================================================
# MITAS 環境変数サンプル
# このファイルを .env にコピーして値を設定してください。
# .env は絶対にコミットしないでください。
# ============================================================

# Netlify DB（Netlify DB を有効化すると自動設定されます）
NETLIFY_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
NETLIFY_DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname?sslmode=require

# 将来の管理 API / 管理画面保護用
ADMIN_SECRET=replace_with_strong_secret

# 将来の認証トークン署名キー
# 生成例: openssl rand -hex 32
SESSION_SECRET=replace_with_random_32_char_string

# 運営デフォルト担当者名（案件作成時の初期値に利用予定）
DEFAULT_CASE_OWNER=Konchi

# 通知送信元メールアドレス
NOTIFICATION_FROM_EMAIL=neco.oncall@gmail.com
